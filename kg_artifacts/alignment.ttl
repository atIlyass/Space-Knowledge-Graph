@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skg-o: <http://space-kg.org/ontology/> .
@prefix skg-r: <http://space-kg.org/resource/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix wd-prop: <http://www.wikidata.org/prop/direct/> .

skg-o:discoveredBy a owl:ObjectProperty ;
    rdfs:comment "Aligned to wd:P61. P61 = 'discoverer or inventor' — direct equivalent" ;
    owl:equivalentProperty wd-prop:P61 .

skg-o:hasAstronaut a owl:ObjectProperty ;
    rdfs:comment "Aligned to wd:P1029. P1029 = 'crew member' — direct equivalent" ;
    owl:equivalentProperty wd-prop:P1029 .

skg-o:isCommanderOf a owl:ObjectProperty ;
    rdfs:comment "Aligned to wd:P1344. P1344 = 'participant in' — isCommanderOf is a specialisation" ;
    rdfs:subPropertyOf wd-prop:P1344 .

skg-o:landedOn a owl:ObjectProperty ;
    rdfs:comment "Aligned to wd:P65. P65 = 'site of astronomical discovery' is closest; approximate" ;
    owl:equivalentProperty wd-prop:P65 .

skg-o:launchedBy a owl:ObjectProperty ;
    rdfs:comment "Aligned to wd:P137. P137 = 'operator' — equivalent for space missions" ;
    owl:equivalentProperty wd-prop:P137 .

skg-o:locatedIn a owl:ObjectProperty ;
    rdfs:comment "Aligned to wd:P131. P131 = 'located in the administrative territorial entity' is broader" ;
    rdfs:subPropertyOf wd-prop:P131 .

skg-o:partOf a owl:ObjectProperty ;
    rdfs:comment "Aligned to wd:P361. P361 = 'part of' — exact equivalent" ;
    owl:equivalentProperty wd-prop:P361 .

