@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skg: <http://space-kg.org/ontology/> .

skg: a owl:Ontology ;
    rdfs:label "Space Exploration Knowledge Graph Ontology" ;
    rdfs:comment "Minimal ontology for the space-exploration domain. Generated by the Web Datamining & Semantics project." .

skg:MissionCommander a owl:Class ;
    rdfs:comment "An astronaut who commands a space mission. Inferred via SWRL." ;
    rdfs:subClassOf skg:Astronaut .

skg:Telescope a owl:Class ;
    rdfs:label "Telescope" ;
    rdfs:comment "An instrument for observing distant celestial objects." ;
    rdfs:subClassOf skg:Spacecraft .

skg:discoveredBy a owl:ObjectProperty ;
    rdfs:label "discoveredBy" ;
    rdfs:comment "The person credited with discovering a celestial body." ;
    rdfs:domain skg:CelestialBody ;
    rdfs:range skg:Person .

skg:hasAstronaut a owl:ObjectProperty ;
    rdfs:label "hasAstronaut" ;
    rdfs:comment "Links a mission to a crew member." ;
    rdfs:domain skg:SpaceMission ;
    rdfs:range skg:Astronaut .

skg:isCommanderOf a owl:ObjectProperty ;
    rdfs:label "isCommanderOf" ;
    rdfs:comment "An astronaut commands a specific mission." ;
    rdfs:domain skg:Astronaut ;
    rdfs:range skg:SpaceMission .

skg:landedOn a owl:ObjectProperty ;
    rdfs:label "landedOn" ;
    rdfs:comment "The celestial body on which a mission landed." ;
    rdfs:domain skg:SpaceMission ;
    rdfs:range skg:CelestialBody .

skg:launchedBy a owl:ObjectProperty ;
    rdfs:label "launchedBy" ;
    rdfs:comment "Indicates the agency that launched the mission." ;
    rdfs:domain skg:SpaceMission ;
    rdfs:range skg:SpaceAgency .

skg:locatedIn a owl:ObjectProperty ;
    rdfs:label "locatedIn" ;
    rdfs:comment "Spatial containment relationship." .

skg:partOf a owl:ObjectProperty ;
    rdfs:label "partOf" ;
    rdfs:comment "Generic part-of relationship." .

skg:SpaceAgency a owl:Class ;
    rdfs:label "SpaceAgency" ;
    rdfs:comment "A governmental or commercial organisation conducting space activities." .

skg:Spacecraft a owl:Class ;
    rdfs:label "Spacecraft" ;
    rdfs:comment "A vehicle designed to travel in outer space." .

skg:CelestialBody a owl:Class ;
    rdfs:label "CelestialBody" ;
    rdfs:comment "A naturally occurring astronomical object (planet, moon, asteroid …)." .

skg:Person a owl:Class ;
    rdfs:label "Person" .

skg:Astronaut a owl:Class ;
    rdfs:label "Astronaut" ;
    rdfs:comment "A person trained and certified to travel in space." ;
    rdfs:subClassOf skg:Person .

skg:SpaceMission a owl:Class ;
    rdfs:label "SpaceMission" ;
    rdfs:comment "A crewed or uncrewed mission conducted in outer space." .

